<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  No special capabilities are declared. Sign-in (phone OTP + Sign in with
	  Apple) has been removed and the app runs in offline demo mode, so it builds
	  and runs on a free / personal Apple Developer team.

	  If you reintroduce auth or push later, re-add the relevant entitlements
	  (requires the paid Apple Developer Program), e.g.:

	    <key>com.apple.developer.applesignin</key>
	    <array><string>Default</string></array>
	    <key>aps-environment</key>
	    <string>development</string>
	-->
</dict>
</plist>
