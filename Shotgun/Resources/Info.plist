<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>Shotgun</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>

	<!-- Export compliance: no non-exempt encryption, so TestFlight skips the prompt. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- Supabase config, injected from Config/Secrets.xcconfig at build time. -->
	<key>SUPABASE_URL</key>
	<string>$(SUPABASE_URL)</string>
	<key>SUPABASE_ANON_KEY</key>
	<string>$(SUPABASE_ANON_KEY)</string>

	<!-- Push notifications -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>

	<!-- Permission strings -->
	<key>NSContactsUsageDescription</key>
	<string>Shotgun finds friends who are already on the app from your contacts.</string>
	<key>NSCameraUsageDescription</key>
	<string>Add a profile photo by taking a picture.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Choose a profile photo from your library.</string>

	<!-- Allow opening the Venmo app for the payment handoff. -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>venmo</string>
	</array>

	<!-- Custom URL scheme for auth callbacks / deep links. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>shotgun</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
